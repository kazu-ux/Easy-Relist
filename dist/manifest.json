{
  "name": "らくらく再出品",
  "description": "メルカリの再出品を支援します。",
  "version": "1.3",
  "manifest_version": 3,
  "icons": {
    "16": "/icons/16.png",
    "32": "/icons/32.png",
    "48": "/icons/48.png",
    "128": "/icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["scripting", "webRequest", "storage"],
  "host_permissions": [
    "https://jp.mercari.com/transaction/*",
    "https://jp.mercari.com/item/*",
    "https://api.mercari.jp/items/*",
    "https://fril.jp/item/new"
  ]
}
